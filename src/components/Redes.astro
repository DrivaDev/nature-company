---
const instagramHref = "https://www.instagram.com/naturecompany_/";
---

<section class="bg-brown px-5 py-24 text-center sm:px-8 sm:py-28">
  <div class="mx-auto max-w-2xl">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-tan">Nuestras redes</p>
    <h2 class="section-title mt-4 text-4xl text-cream sm:text-5xl">Seguinos en Instagram</h2>
    <p class="mt-6 text-lg text-cream/80">
      Seguinos en Instagram para descubrir más sobre nuestra cocina natural, conocer las novedades de nuestro
      menú y ser parte de la comunidad Nature.
    </p>
    <a href={instagramHref} target="_blank" rel="noopener noreferrer" class="btn btn-cream mt-9">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
      </svg>
      @naturecompany_
    </a>
  </div>
</section>
