---
import { Image } from "astro:assets";
import img1 from "../assets/images/pan-artesanal-1.jpg";
import img2 from "../assets/images/interior-ambiente.jpg";
import img3 from "../assets/images/nuestro-menu.png";
import img4 from "../assets/images/pan-artesanal-2.jpg";
import img5 from "../assets/images/chef-juan-manzo.jpg";
import img6 from "../assets/images/fachada-nature-co.jpg";

const instagramHref = "https://www.instagram.com/naturecompany_/";
const gallery = [
  { src: img1, alt: "Pan artesanal recién horneado" },
  { src: img2, alt: "Ambiente interior del restaurante" },
  { src: img3, alt: "Plato de estación emplatado" },
  { src: img4, alt: "Pan de masa madre" },
  { src: img5, alt: "El chef Juan Manzo en la cocina" },
  { src: img6, alt: "Fachada de Nature Company Resto" },
];
---

<section id="redes" class="bg-cream-soft px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="section-eyebrow">Nuestras redes</p>
      <h2 class="mt-3 font-display text-4xl text-brown sm:text-5xl">Seguinos en Instagram</h2>
      <a
        href={instagramHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block text-lg font-medium text-orange transition-colors hover:text-orange-dark"
      >
        @naturecompany_
      </a>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
      {
        gallery.map((item) => (
          <a
            href={instagramHref}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative aspect-square overflow-hidden rounded-2xl"
            aria-label="Ver en Instagram"
          >
            <Image
              src={item.src}
              alt={item.alt}
              widths={[320, 480, 640]}
              sizes="(min-width: 640px) 30vw, 45vw"
              format="webp"
              quality={78}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <span class="absolute inset-0 flex items-center justify-center bg-brown/0 opacity-0 transition-all duration-300 group-hover:bg-brown/40 group-hover:opacity-100">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-9 w-9" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <a href={instagramHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Seguinos en Instagram
      </a>
    </div>
  </div>
</section>
