---
const redes = [
  {
    name: "Instagram",
    handle: "@naturecompany_",
    href: "https://www.instagram.com/naturecompany_/",
    icon: "instagram",
  },
  {
    name: "Facebook",
    handle: "Nature Company Resto",
    href: "https://www.facebook.com/profile.php?id=61573831691007",
    icon: "facebook",
  },
];
---

<section id="redes" class="bg-cream-soft px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl">
      <p class="section-eyebrow">Nuestras redes</p>
      <h2 class="mt-3 font-display text-4xl text-brown sm:text-5xl">Seguinos y sumate a la comunidad</h2>
      <p class="mt-6 text-lg leading-relaxed text-ink-muted">
        Compartimos platos de estación, novedades y el detrás de escena de la cocina. Seguinos para no perderte nada.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2">
      {
        redes.map((red) => (
          <a
            href={red.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 rounded-3xl border border-brown/15 bg-cream p-7 transition-transform duration-300 hover:-translate-y-1"
          >
            <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brown text-cream-soft transition-colors group-hover:bg-orange">
              {red.icon === "instagram" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                </svg>
              )}
              {red.icon === "facebook" && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-8 w-8" aria-hidden="true">
                  <path d="M14 9h3l.5-3H14V4.2c0-.9.3-1.5 1.6-1.5H17.6V0.1C17.2.05 16.1 0 15 0c-2.4 0-4 1.4-4 4v2H8v3h3v9h3V9Z" />
                </svg>
              )}
            </span>
            <div>
              <h3 class="font-display text-2xl leading-none text-brown">{red.name}</h3>
              <p class="mt-2 text-ink-muted">{red.handle}</p>
            </div>
            <span class="ml-auto text-brown transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
