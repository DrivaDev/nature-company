---
import { Image } from "astro:assets";
import heroImage from "../assets/images/fachada-nature-co.jpg";

const menuHref = "https://drive.google.com/file/d/17GD3KPfyQW8ZpE1CcwVPkIMk1GguuJFE/view";
---

<section id="inicio" class="relative flex min-h-[92svh] items-center justify-center overflow-hidden pt-20">
  <Image
    src={heroImage}
    alt="Fachada de Nature Company Resto, restaurante natural en Martínez cubierto de enredadera"
    widths={[640, 1024, 1600, 2200]}
    sizes="100vw"
    format="webp"
    quality={80}
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    style="object-position: 50% 40%;"
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 -z-10 bg-ink/35" aria-hidden="true"></div>

  <div class="mx-auto w-full max-w-[1200px] px-5 text-center sm:px-8">
    <a
      href={menuHref}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-cream text-base sm:text-lg"
    >
      ¡Descubrí nuestra oferta gastronómica aquí!
    </a>
  </div>
</section>
