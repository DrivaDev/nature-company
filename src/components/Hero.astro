---
import { Image } from "astro:assets";
import heroImage from "../assets/images/hero.png";
---

<section id="inicio" class="bg-cream">
  <Image
    src={heroImage}
    alt="Bienvenidos a Nature — cocina 70% plant-based, sin TACC y proteínas sostenibles en Martínez"
    widths={[640, 1024, 1600, 1920]}
    sizes="100vw"
    format="webp"
    quality={82}
    class="block w-full"
    loading="eager"
    fetchpriority="high"
  />
</section>

<script>
  const header = document.getElementById("site-header");
  const hero = document.getElementById("inicio");

  if (header && hero) {
    const syncOffset = () => {
      hero.style.paddingTop = `${header.offsetHeight}px`;
    };
    syncOffset();
    window.addEventListener("resize", syncOffset);
    window.addEventListener("load", syncOffset);
  }
</script>
