---
const whatsappHref =
  "https://api.whatsapp.com/send/?phone=5491171434499&text=Buen+d%C3%ADa%2C+quisiera+reservar+una+mesa";
---

<section class="bg-brown px-5 py-24 text-center sm:px-8 sm:py-28">
  <div class="mx-auto max-w-2xl">
    <p class="section-eyebrow text-lime">Reservá tu mesa</p>
    <h2 class="mt-3 font-display text-4xl text-cream-soft sm:text-5xl">No te quedes sin tu lugar</h2>
    <p class="mt-6 text-lg text-cream-soft/85">
      Reservá tu mesa y te esperamos listos para darte el mejor servicio.
    </p>
    <a
      href={whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
      class="btn mt-9 bg-cream-soft text-brown hover:bg-lime"
    >
      Reservar por WhatsApp
    </a>
  </div>
</section>
