---
const whatsappHref =
  "https://api.whatsapp.com/send/?phone=5491171434499&text=Buen+d%C3%ADa%2C+quisiera+reservar+una+mesa";
---

<section class="bg-blue px-5 py-24 text-center sm:px-8 sm:py-28">
  <div class="mx-auto max-w-2xl">
    <h2 class="section-title text-4xl text-cream sm:text-5xl">Reservá tu mesa</h2>
    <p class="mt-6 text-lg text-cream/85">
      No te quedes sin tu lugar. Reservá tu mesa y te esperamos listos para darte el mejor servicio.
    </p>
    <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="btn btn-cream mt-9">
      Reservar mesa
    </a>
  </div>
</section>
