---
import Lightbox from "./Lightbox.astro";

// Galería: grid de 6 columnas (aspect 3/4), hover con scale y lightbox al click.
//
// Imágenes reales en public/images/galeria/ (extensiones respetan mayúsculas
// exactas del archivo: importa en deploys case-sensitive como Vercel/Linux).
const images = [
  { src: "/images/galeria/galeria-01.jpg", alt: "Galería Nature Company — foto 1" },
  { src: "/images/galeria/galeria-02.jpg", alt: "Galería Nature Company — foto 2" },
  { src: "/images/galeria/galeria-03.jpg", alt: "Galería Nature Company — foto 3" },
  { src: "/images/galeria/galeria-04.jpg", alt: "Galería Nature Company — foto 4" },
  { src: "/images/galeria/galeria-05.jpg", alt: "Galería Nature Company — foto 5" },
  { src: "/images/galeria/galeria-06.jpg", alt: "Galería Nature Company — foto 6" },
  { src: "/images/galeria/galeria-07.JPG", alt: "Galería Nature Company — foto 7" },
  { src: "/images/galeria/galeria-08.JPG", alt: "Galería Nature Company — foto 8" },
  { src: "/images/galeria/galeria-09.JPG", alt: "Galería Nature Company — foto 9" },
  { src: "/images/galeria/galeria-10.JPG", alt: "Galería Nature Company — foto 10" },
  { src: "/images/galeria/galeria-11.jpg", alt: "Galería Nature Company — foto 11" },
];
---

<section id="galeria" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="section-eyebrow">Galería</p>
      <h2 class="mt-3 font-display text-4xl text-brown sm:text-5xl">Momentos en Nature</h2>
      <p class="mt-6 text-lg leading-relaxed text-ink-muted">
        Un recorrido por nuestros platos, el ambiente y los detalles que hacen a la experiencia.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-3 gap-2 sm:grid-cols-4 sm:gap-3 lg:grid-cols-6">
      {
        images.map((img) => (
          <button
            type="button"
            data-lightbox-trigger
            data-src={img.src}
            data-alt={img.alt}
            aria-label={`Ampliar imagen: ${img.alt}`}
            class="group relative aspect-[3/4] cursor-pointer overflow-hidden rounded-lg border border-brown/15 transition-[border-color,transform] duration-200 hover:border-green"
          >
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>
  </div>
</section>

<Lightbox />
