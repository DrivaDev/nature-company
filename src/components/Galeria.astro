---
// Galería: fila única de platos que se desplaza en loop de izquierda a
// derecha (marquee). No es clickeable. Sin lightbox.
//
// Imágenes reales en public/images/galeria/ (extensiones respetan mayúsculas
// exactas del archivo: importa en deploys case-sensitive como Vercel/Linux).
const images = [
  { src: "/images/galeria/galeria-01.jpg", alt: "Plato Nature Company — foto 1" },
  { src: "/images/galeria/galeria-02.jpg", alt: "Plato Nature Company — foto 2" },
  { src: "/images/galeria/galeria-03.jpg", alt: "Plato Nature Company — foto 3" },
  { src: "/images/galeria/galeria-04.jpg", alt: "Plato Nature Company — foto 4" },
  { src: "/images/galeria/galeria-05.jpg", alt: "Plato Nature Company — foto 5" },
  { src: "/images/galeria/galeria-06.jpg", alt: "Plato Nature Company — foto 6" },
  { src: "/images/galeria/galeria-07.JPG", alt: "Plato Nature Company — foto 7" },
  { src: "/images/galeria/galeria-08.JPG", alt: "Plato Nature Company — foto 8" },
  { src: "/images/galeria/galeria-09.JPG", alt: "Plato Nature Company — foto 9" },
  { src: "/images/galeria/galeria-10.JPG", alt: "Plato Nature Company — foto 10" },
  { src: "/images/galeria/galeria-11.jpg", alt: "Plato Nature Company — foto 11" },
];

// Se duplica la lista para lograr el loop continuo sin cortes.
const track = [...images, ...images];
---

<section id="galeria" class="overflow-hidden bg-cream py-24 sm:py-32">
  <div class="mx-auto max-w-2xl px-5 text-center sm:px-8">
    <p class="section-eyebrow">Galería</p>
    <h2 class="mt-3 font-display text-4xl text-brown sm:text-5xl">Nuestros platos</h2>
    <p class="mt-6 text-lg leading-relaxed text-ink-muted">
      Un recorrido por nuestros platos y los detalles que hacen a la experiencia.
    </p>
  </div>

  <div class="marquee mx-auto mt-12 max-w-7xl overflow-hidden px-5 sm:px-8">
    <div class="marquee-track flex w-max gap-4">
      {
        track.map((img, i) => (
          <div class="relative aspect-[3/4] w-36 shrink-0 overflow-hidden rounded-lg border border-brown/15 sm:w-44">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              aria-hidden={i >= images.length ? "true" : undefined}
              class="absolute inset-0 h-full w-full object-cover object-center"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Loop de -50% a 0 => la fila se desplaza de izquierda a derecha.
     Como el track está duplicado, el reinicio es imperceptible. */
  @keyframes gallery-scroll {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  /* Difuminado a los costados: las imágenes desaparecen suavemente
     en los bordes en lugar de cortarse de golpe. */
  .marquee {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 12%,
      #000 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 12%,
      #000 88%,
      transparent 100%
    );
  }

  .marquee-track {
    animation: gallery-scroll 45s linear infinite;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
