---
// Lightbox.astro — visor modal reutilizable.
// Se auto-inicializa: busca en la página todos los [data-lightbox-trigger],
// arma la lista de imágenes según su orden en el DOM y maneja:
//   - apertura al hacer click en un trigger
//   - navegación por teclado (Escape / flechas)
//   - botones anterior / siguiente (con wrap circular)
// No usa React ni frameworks: solo un <script> del lado del cliente.
---

<div
  id="lightbox"
  class="fixed inset-0 z-[200] hidden items-center justify-center bg-ink/95 p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Visor de imagen"
  aria-hidden="true"
  data-lightbox
>
  {/* Cerrar */}
  <button
    type="button"
    data-lb-close
    aria-label="Cerrar visor"
    class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-full border border-cream/20 bg-cream/10 text-cream transition-colors hover:bg-cream/20"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
      <path d="M18 6 6 18" />
      <path d="m6 6 12 12" />
    </svg>
  </button>

  {/* Anterior */}
  <button
    type="button"
    data-lb-prev
    aria-label="Imagen anterior"
    class="absolute left-4 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-cream/20 bg-cream/10 text-cream transition-colors hover:bg-cream/20"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
      <path d="m15 18-6-6 6-6" />
    </svg>
  </button>

  {/* Imagen */}
  <div class="relative max-h-[80vh] max-w-[90vw]">
    <img
      data-lb-img
      src=""
      alt=""
      class="block max-h-[80vh] max-w-[90vw] rounded-md object-contain"
    />
    <div
      data-lb-counter
      class="absolute -bottom-8 left-1/2 -translate-x-1/2 whitespace-nowrap font-body text-sm text-cream/70"
    >
    </div>
  </div>

  {/* Siguiente */}
  <button
    type="button"
    data-lb-next
    aria-label="Siguiente imagen"
    class="absolute right-4 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-cream/20 bg-cream/10 text-cream transition-colors hover:bg-cream/20"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
      <path d="m9 18 6-6-6-6" />
    </svg>
  </button>
</div>

<script>
  const modal = document.getElementById("lightbox");
  if (modal) {
    const imgEl = modal.querySelector<HTMLImageElement>("[data-lb-img]")!;
    const counterEl = modal.querySelector<HTMLElement>("[data-lb-counter]")!;
    const closeBtn = modal.querySelector<HTMLButtonElement>("[data-lb-close]")!;
    const prevBtn = modal.querySelector<HTMLButtonElement>("[data-lb-prev]")!;
    const nextBtn = modal.querySelector<HTMLButtonElement>("[data-lb-next]")!;

    // Construir la lista de imágenes a partir de los triggers de la página.
    const triggers = Array.from(
      document.querySelectorAll<HTMLElement>("[data-lightbox-trigger]")
    );
    const images = triggers.map((t) => ({
      src: t.dataset.src || "",
      alt: t.dataset.alt || "",
    }));

    let current = 0;

    function render() {
      const item = images[current];
      if (!item) return;
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      counterEl.textContent = `${current + 1} / ${images.length}`;
      // Ocultar flechas si hay una sola imagen.
      const many = images.length > 1;
      prevBtn.style.display = many ? "flex" : "none";
      nextBtn.style.display = many ? "flex" : "none";
    }

    function open(index: number) {
      current = index;
      render();
      modal!.classList.remove("hidden");
      modal!.classList.add("flex");
      modal!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      document.addEventListener("keydown", onKey);
    }

    function close() {
      modal!.classList.add("hidden");
      modal!.classList.remove("flex");
      modal!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      document.removeEventListener("keydown", onKey);
    }

    function next() {
      current = current === images.length - 1 ? 0 : current + 1;
      render();
    }

    function prev() {
      current = current === 0 ? images.length - 1 : current - 1;
      render();
    }

    function onKey(e: KeyboardEvent) {
      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") next();
      if (e.key === "ArrowLeft") prev();
    }

    triggers.forEach((t, i) => t.addEventListener("click", () => open(i)));
    closeBtn.addEventListener("click", close);
    nextBtn.addEventListener("click", next);
    prevBtn.addEventListener("click", prev);

    // Cerrar al hacer click en el fondo (fuera de la imagen).
    modal.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });
  }
</script>
