---
const links = [
  { href: "#inicio", label: "Inicio" },
  { href: "#propuesta", label: "Propuesta" },
  { href: "#chef", label: "El chef" },
  { href: "#menu", label: "Menú" },
  { href: "#redes", label: "Nuestras redes" },
  { href: "#encontranos", label: "Encontranos" },
];

const menuHref = "https://drive.google.com/file/d/17GD3KPfyQW8ZpE1CcwVPkIMk1GguuJFE/view";
const whatsappHref =
  "https://api.whatsapp.com/send/?phone=5491171434499&text=Buen+d%C3%ADa%2C+quisiera+reservar+una+mesa";
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <a
    href={menuHref}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center bg-cream px-4 py-2.5 text-center text-sm font-normal tracking-wide text-brown transition-colors hover:bg-cream-soft"
  >
    ¡Descubrí nuestra oferta gastronómica aquí!
  </a>

  <div class="border-b border-cream-soft/10 bg-brown">
    <nav
      class="mx-auto grid max-w-7xl grid-cols-[1fr_auto_1fr] items-center px-5 py-3 sm:px-8"
      aria-label="Navegación principal"
    >
      <div class="flex justify-start">
        <button
          id="menu-toggle"
          type="button"
          class="group relative h-11 w-11"
          aria-expanded="false"
          aria-controls="sidebar-menu"
          aria-label="Abrir menú de navegación"
        >
          <span class="absolute left-1/2 top-1/2 block h-0.5 w-5 -translate-x-1/2 -translate-y-[5px] rounded-full bg-cream-soft/70 transition-transform duration-300 ease-out group-hover:bg-cream-soft group-aria-expanded:translate-y-0 group-aria-expanded:rotate-45"></span>
          <span class="absolute left-1/2 top-1/2 block h-0.5 w-5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cream-soft/70 transition-opacity duration-200 ease-out group-hover:bg-cream-soft group-aria-expanded:opacity-0"></span>
          <span class="absolute left-1/2 top-1/2 block h-0.5 w-5 -translate-x-1/2 translate-y-[3px] rounded-full bg-cream-soft/70 transition-transform duration-300 ease-out group-hover:bg-cream-soft group-aria-expanded:translate-y-0 group-aria-expanded:-rotate-45"></span>
        </button>
      </div>

      <a href="#inicio" class="flex items-center justify-center" aria-label="Nature Company Resto, inicio">
        <img
          src="/images/logo.svg"
          alt="Nature Company Resto - Fábrica de la tierra, resto natural"
          width="56"
          height="56"
          class="h-12 w-12 brightness-0 invert sm:h-14 sm:w-14"
        />
      </a>

      <div class="flex justify-end">
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden rounded-full border border-cream-soft/30 px-4 py-1.5 text-sm font-medium text-cream-soft/90 transition-colors hover:border-cream-soft/60 hover:text-cream-soft lg:inline-flex"
        >
          Reservar mesa
        </a>
      </div>
    </nav>
  </div>
</header>

<aside
  id="sidebar-menu"
  class="fixed bottom-0 left-0 z-40 flex w-80 max-w-[85vw] -translate-x-full flex-col bg-cream-soft text-brown shadow-2xl transition-transform duration-300 ease-out"
  aria-hidden="true"
>
  <nav class="flex flex-1 flex-col overflow-y-auto py-4" aria-label="Menú lateral">
    {
      links.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            "px-8 py-4 text-xl font-medium text-ink transition-colors hover:bg-cream",
            i === 0 && "bg-cream",
          ]}
          data-sidebar-link
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="flex items-center gap-5 border-t border-brown/10 px-8 py-6">
    <a
      href="https://www.facebook.com/profile.php?id=61573831691007"
      target="_blank"
      rel="noopener noreferrer"
      class="text-brown transition-colors hover:text-orange"
      aria-label="Facebook"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
        <path d="M14 9h3l.5-3H14V4.2c0-.9.3-1.5 1.6-1.5H17.6V0.1C17.2.05 16.1 0 15 0c-2.4 0-4 1.4-4 4v2H8v3h3v9h3V9Z" />
      </svg>
    </a>
    <a
      href="https://www.instagram.com/naturecompany_/"
      target="_blank"
      rel="noopener noreferrer"
      class="text-brown transition-colors hover:text-orange"
      aria-label="Instagram"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
      </svg>
    </a>
  </div>
</aside>

<div
  id="menu-backdrop"
  class="fixed inset-0 z-30 bg-ink/50 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
</div>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");
  const sidebar = document.getElementById("sidebar-menu");
  const backdrop = document.getElementById("menu-backdrop");

  if (header && toggle && sidebar && backdrop) {
    const syncTop = () => {
      const h = header.offsetHeight;
      sidebar.style.top = `${h}px`;
      backdrop.style.top = `${h}px`;
    };
    syncTop();
    window.addEventListener("resize", syncTop);

    const openMenu = () => {
      syncTop();
      toggle.setAttribute("aria-expanded", "true");
      sidebar.setAttribute("aria-hidden", "false");
      sidebar.classList.remove("-translate-x-full");
      backdrop.classList.remove("opacity-0", "pointer-events-none");
      backdrop.classList.add("opacity-100", "pointer-events-auto");
      document.body.classList.add("overflow-hidden");
    };

    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      sidebar.setAttribute("aria-hidden", "true");
      sidebar.classList.add("-translate-x-full");
      backdrop.classList.remove("opacity-100", "pointer-events-auto");
      backdrop.classList.add("opacity-0", "pointer-events-none");
      document.body.classList.remove("overflow-hidden");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    backdrop.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu();
        toggle.focus();
      }
    });

    sidebar.querySelectorAll("[data-sidebar-link]").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }
</script>
