---
const menuHref = "https://drive.google.com/file/d/17GD3KPfyQW8ZpE1CcwVPkIMk1GguuJFE/view";
const whatsappHref =
  "https://api.whatsapp.com/send/?phone=5491171434499&text=Buen+d%C3%ADa%2C+quisiera+reservar+una+mesa";

const links = [
  { href: "#inicio", label: "Inicio" },
  { href: menuHref, label: "Menú", external: true },
  { href: "#cafeteria", label: "Menú Cafetería" },
  { href: "#platos", label: "Blog" },
  { href: "#encontranos", label: "Contacto" },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-brown/10 bg-cream/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-[1200px] items-center justify-between px-5 py-3 sm:px-8" aria-label="Navegación principal">
    <a href="#inicio" class="flex items-center gap-2" aria-label="Nature Company Resto, inicio">
      <img
        src="/images/logo.svg"
        alt="Nature Company Resto"
        width="52"
        height="52"
        class="h-11 w-11"
      />
    </a>

    <ul class="hidden items-center gap-7 lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class="text-sm font-medium tracking-wide text-brown transition-colors hover:text-brown-soft"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary hidden lg:inline-flex"
      >
        Reservar mesa
      </a>

      <a href="#" aria-label="Perfil / Iniciar sesión" class="hidden text-brown transition-colors hover:text-brown-soft lg:inline-flex">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-6 w-6" aria-hidden="true">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 21c0-4 4-6 8-6s8 2 8 6" stroke-linecap="round" />
        </svg>
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="group flex h-11 w-11 flex-col items-center justify-center gap-1.5 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
      >
        <span class="block h-0.5 w-6 origin-center bg-brown transition-transform duration-300 ease-out group-aria-expanded:translate-y-2 group-aria-expanded:rotate-45"></span>
        <span class="block h-0.5 w-6 bg-brown transition-opacity duration-200 ease-out group-aria-expanded:opacity-0"></span>
        <span class="block h-0.5 w-6 origin-center bg-brown transition-transform duration-300 ease-out group-aria-expanded:-translate-y-2 group-aria-expanded:-rotate-45"></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden opacity-0 transition-[grid-template-rows,opacity] duration-300 ease-out lg:hidden"
  >
    <div class="flex min-h-0 flex-col gap-1 overflow-hidden border-t border-brown/10 bg-cream px-5 pb-6 pt-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class="rounded-lg px-3 py-3 text-base font-medium text-brown hover:bg-cream-soft"
            data-mobile-link
          >
            {link.label}
          </a>
        ))
      }
      <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary mt-3 justify-center">
        Reservar mesa
      </a>
    </div>
  </div>
</header>

<div
  id="menu-backdrop"
  class="fixed inset-0 z-40 bg-ink/50 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("menu-backdrop");

  if (toggle && menu && backdrop) {
    const openMenu = () => {
      toggle.setAttribute("aria-expanded", "true");
      menu.classList.remove("grid-rows-[0fr]", "opacity-0");
      menu.classList.add("grid-rows-[1fr]", "opacity-100");
      backdrop.classList.remove("opacity-0", "pointer-events-none");
      backdrop.classList.add("opacity-100", "pointer-events-auto");
      document.body.classList.add("overflow-hidden");
    };

    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.classList.remove("grid-rows-[1fr]", "opacity-100");
      menu.classList.add("grid-rows-[0fr]", "opacity-0");
      backdrop.classList.remove("opacity-100", "pointer-events-auto");
      backdrop.classList.add("opacity-0", "pointer-events-none");
      document.body.classList.remove("overflow-hidden");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    backdrop.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu();
        toggle.focus();
      }
    });

    menu.querySelectorAll("[data-mobile-link]").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024 && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu();
      }
    });
  }
</script>
