---
const links = [
  { href: "#propuesta", label: "Propuesta" },
  { href: "#chef", label: "El chef" },
  { href: "#menu", label: "Menú" },
  { href: "#redes", label: "Nuestras redes" },
  { href: "#encontranos", label: "Encontranos" },
];

const menuHref = "https://drive.google.com/file/d/17GD3KPfyQW8ZpE1CcwVPkIMk1GguuJFE/view";
const whatsappHref =
  "https://api.whatsapp.com/send/?phone=5491171434499&text=Buen+d%C3%ADa%2C+quisiera+reservar+una+mesa";
---

<header class="fixed inset-x-0 top-0 z-50">
  <a
    href={menuHref}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center gap-2 bg-orange px-4 py-2.5 text-center text-sm font-semibold tracking-wide text-cream-soft transition-colors hover:bg-orange-dark"
  >
    <span>¡Descubrí nuestra oferta gastronómica aquí!</span>
    <span aria-hidden="true">→</span>
  </a>

  <div class="border-b border-cream-soft/10 bg-brown">
    <nav
      class="mx-auto grid max-w-7xl grid-cols-[1fr_auto_1fr] items-center px-5 py-3 sm:px-8"
      aria-label="Navegación principal"
    >
      <div class="flex justify-start">
        <button
          id="menu-toggle"
          type="button"
          class="group flex h-11 w-11 flex-col items-center justify-center gap-1.5"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú de navegación"
        >
          <span class="block h-0.5 w-6 origin-center bg-cream-soft transition-transform duration-300 ease-out group-aria-expanded:translate-y-2 group-aria-expanded:rotate-45" data-bar="1"></span>
          <span class="block h-0.5 w-6 bg-cream-soft transition-opacity duration-200 ease-out group-aria-expanded:opacity-0" data-bar="2"></span>
          <span class="block h-0.5 w-6 origin-center bg-cream-soft transition-transform duration-300 ease-out group-aria-expanded:-translate-y-2 group-aria-expanded:-rotate-45" data-bar="3"></span>
        </button>
      </div>

      <a href="#inicio" class="flex items-center justify-center" aria-label="Nature Company Resto, inicio">
        <img
          src="/images/logo.svg"
          alt="Nature Company Resto - Fábrica de la tierra, resto natural"
          width="56"
          height="56"
          class="h-12 w-12 brightness-0 invert sm:h-14 sm:w-14"
        />
      </a>

      <div class="flex justify-end">
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-on-dark hidden lg:inline-flex"
        >
          Reservar mesa
        </a>
      </div>
    </nav>
  </div>

  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden opacity-0 transition-[grid-template-rows,opacity] duration-300 ease-out"
  >
    <div class="flex min-h-0 flex-col gap-1 overflow-hidden border-t border-cream-soft/10 bg-brown px-5 pb-6 pt-2">
      {
        links.map((link) => (
          <a href={link.href} class="rounded-lg px-3 py-3 text-base font-medium text-cream-soft hover:bg-brown-soft" data-mobile-link>
            {link.label}
          </a>
        ))
      }
      <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="btn btn-on-dark mt-3 justify-center">
        Reservar mesa
      </a>
    </div>
  </div>
</header>

<div
  id="menu-backdrop"
  class="fixed inset-0 z-40 bg-ink/50 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("menu-backdrop");

  if (toggle && menu && backdrop) {
    const openMenu = () => {
      toggle.setAttribute("aria-expanded", "true");
      menu.classList.remove("grid-rows-[0fr]", "opacity-0");
      menu.classList.add("grid-rows-[1fr]", "opacity-100");
      backdrop.classList.remove("opacity-0", "pointer-events-none");
      backdrop.classList.add("opacity-100", "pointer-events-auto");
      document.body.classList.add("overflow-hidden");
    };

    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.classList.remove("grid-rows-[1fr]", "opacity-100");
      menu.classList.add("grid-rows-[0fr]", "opacity-0");
      backdrop.classList.remove("opacity-100", "pointer-events-auto");
      backdrop.classList.add("opacity-0", "pointer-events-none");
      document.body.classList.remove("overflow-hidden");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    backdrop.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu();
        toggle.focus();
      }
    });

    menu.querySelectorAll("[data-mobile-link]").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }
</script>
