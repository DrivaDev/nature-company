---
import { Image } from "astro:assets";
import menuImage from "../assets/images/nuestro-menu.png";

const menuHref = "https://drive.google.com/file/d/17GD3KPfyQW8ZpE1CcwVPkIMk1GguuJFE/view";
---

<section id="cafeteria" class="bg-tan px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto grid max-w-[1200px] items-center gap-12 lg:grid-cols-2 lg:gap-20">
    <div class="order-2 lg:order-1">
      <h2 class="section-title text-4xl text-brown sm:text-5xl">Nuestro menú</h2>
      <p class="mt-6 text-lg leading-relaxed text-brown/80">
        Cada plato en Nature está pensado para que disfrutes una experiencia auténtica, natural y llena de sabor.
        Una cocina que combina ingredientes de estación, creatividad y conciencia en cada detalle.
      </p>
      <div class="mt-8">
        <a href={menuHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Ver menú</a>
      </div>
    </div>

    <div class="order-1 flex items-center justify-center lg:order-2">
      <Image
        src={menuImage}
        alt="Plato de cocina natural emplatado en Nature Company Resto"
        widths={[480, 800, 1100]}
        sizes="(min-width: 1024px) 46vw, 90vw"
        format="webp"
        quality={85}
        class="w-full max-w-[520px] object-contain drop-shadow-2xl"
        loading="lazy"
      />
    </div>
  </div>
</section>
