---
import { Image } from "astro:assets";
import panImage from "../assets/images/pan-artesanal-2.jpg";

const menuHref = "https://drive.google.com/file/d/17GD3KPfyQW8ZpE1CcwVPkIMk1GguuJFE/view";
---

<section id="menu" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-2 lg:gap-20">
    <div class="order-2 lg:order-1">
      <p class="section-eyebrow">Nuestro menú</p>
      <h2 class="mt-3 font-display text-4xl text-brown sm:text-5xl">Sabor de estación, hecho con conciencia</h2>
      <p class="mt-6 text-lg leading-relaxed text-ink-muted">
        Cada plato en Nature está pensado para que disfrutes una experiencia auténtica, natural y llena de sabor.
        Una cocina que combina ingredientes de estación, creatividad y conciencia en cada detalle.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={menuHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Ver menú</a>
      </div>
    </div>

    <div class="order-1 aspect-[4/5] overflow-hidden rounded-3xl lg:order-2">
      <Image
        src={panImage}
        alt="Pan artesanal recién horneado, elaborado a mano en Nature Company Resto"
        widths={[480, 800, 1100]}
        sizes="(min-width: 1024px) 46vw, 90vw"
        format="webp"
        quality={82}
        class="h-full w-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
