---
const year = new Date().getFullYear();
---

<footer class="bg-green px-5 py-14 text-cream-soft sm:px-8">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-8 text-center">
    <img
      src="/images/logo.svg"
      alt="Nature Company Resto"
      width="72"
      height="72"
      class="h-16 w-16 brightness-0 invert"
    />

    <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm" aria-label="Redes sociales">
      <a
        href="https://www.instagram.com/naturecompany_/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-orange"
      >
        Instagram
      </a>
      <a
        href="https://www.facebook.com/profile.php?id=61573831691007"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-orange"
      >
        Facebook
      </a>
      <a href="mailto:naturecompanyresto@gmail.com" class="hover:text-orange">naturecompanyresto@gmail.com</a>
    </nav>

    <div class="h-px w-full max-w-xs bg-cream-soft/15"></div>

    <div class="flex flex-col items-center gap-2 text-xs text-cream-soft/70">
      <p>© {year} Nature Company Resto. Todos los derechos reservados.</p>
      <p class="flex items-center gap-1">
        <span>Desarrollado por</span>
        <a
          href="https://drivadev.com.ar"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-cream-soft hover:text-orange"
        >
          Driva Dev
        </a>
      </p>
    </div>
  </div>
</footer>
