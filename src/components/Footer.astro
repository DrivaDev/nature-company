---
const year = new Date().getFullYear();

const links = [
  { href: "#inicio", label: "Inicio" },
  { href: "#propuesta", label: "Propuesta" },
  { href: "#chef", label: "El chef" },
  { href: "#menu", label: "Menú" },
  { href: "#redes", label: "Nuestras redes" },
  { href: "#encontranos", label: "Encontranos" },
];

const instagramHref = "https://www.instagram.com/naturecompany_/";
const facebookHref = "https://www.facebook.com/profile.php?id=61573831691007";
const whatsappHref =
  "https://api.whatsapp.com/send/?phone=5491171434499&text=Buen+d%C3%ADa%2C+quisiera+reservar+una+mesa";
---

<footer class="bg-brown px-5 py-14 text-cream-soft sm:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 sm:grid-cols-3 sm:gap-8">
      <div class="flex justify-center sm:justify-start">
        <img
          src="/images/logo.svg"
          alt="Nature Company Resto"
          width="80"
          height="80"
          class="h-20 w-20 brightness-0 invert"
        />
      </div>

      <div class="flex flex-col items-center gap-4 text-center sm:items-start sm:text-left">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-cream-soft/60">Contacto</h3>
        <div class="flex gap-4">
          <a href={instagramHref} target="_blank" rel="noopener noreferrer" class="text-cream-soft transition-colors hover:text-orange" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a href={facebookHref} target="_blank" rel="noopener noreferrer" class="text-cream-soft transition-colors hover:text-orange" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
              <path d="M14 9h3l.5-3H14V4.2c0-.9.3-1.5 1.6-1.5H17.6V0.1C17.2.05 16.1 0 15 0c-2.4 0-4 1.4-4 4v2H8v3h3v9h3V9Z" />
            </svg>
          </a>
        </div>
        <a href="mailto:naturecompanyresto@gmail.com" class="text-sm text-cream-soft/85 hover:text-orange">
          naturecompanyresto@gmail.com
        </a>
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="text-sm text-cream-soft/85 hover:text-orange">
          WhatsApp +54 9 11 7143-4499
        </a>
      </div>

      <nav class="flex flex-col items-center gap-3 text-center sm:items-start sm:text-left" aria-label="Secciones">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-cream-soft/60">Secciones</h3>
        {
          links.map((link) => (
            <a href={link.href} class="text-sm text-cream-soft/85 hover:text-orange">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-12 border-t border-cream-soft/15 pt-8">
      <div class="flex flex-col items-center gap-2 text-xs text-cream-soft/70">
        <p>© {year} Nature Company Resto. Todos los derechos reservados.</p>
        <p class="flex items-center gap-1">
          <span>Desarrollado por</span>
          <a
            href="https://drivadev.com.ar"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-cream-soft hover:text-orange"
          >
            Driva Dev
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
