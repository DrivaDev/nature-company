---
// Galería "Nuestros platos" — placeholders hasta recibir las fotos de los platos.
// Reemplazar cada bloque por <Image src={...} /> cuando estén las imágenes reales.
const placeholders = Array.from({ length: 6 }, (_, i) => `Plato ${i + 1}`);
---

<section id="platos" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-[1200px]">
    <div class="max-w-2xl">
      <h2 class="section-title text-4xl text-brown sm:text-5xl">Nuestros platos</h2>
      <p class="mt-6 text-lg text-ink-muted">
        Descubrí nuestras propuestas y encontrá tu próximo favorito.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        placeholders.map((label) => (
          <div class="group relative aspect-[4/5] overflow-hidden rounded-3xl bg-rose/40">
            <div class="flex h-full w-full flex-col items-center justify-center gap-3 border-2 border-dashed border-brown/25 text-brown/50">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" class="h-12 w-12" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="3" />
                <circle cx="9" cy="9" r="2" />
                <path d="m3 17 5-5 4 4 3-3 6 6" />
              </svg>
              <span class="text-sm font-medium tracking-wide">{label}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
