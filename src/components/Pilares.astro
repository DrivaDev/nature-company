---
const pilares = [
  {
    title: "Artesanal",
    text: "Hecha a mano, con tiempo",
    icon: "M12 3c-1 3-4 4-4 8a4 4 0 0 0 8 0c0-4-3-5-4-8Z M12 15v6 M9 21h6",
    bg: "bg-brown",
    fg: "text-cream",
    iconBg: "bg-cream/15",
  },
  {
    title: "Sostenible",
    text: "Respeto por el origen",
    icon: "M4 12c0-4 3-8 8-8 0 5-2 8-8 8Z M20 12c0 4-3 8-8 8 0-5 2-8 8-8Z M12 4v16",
    bg: "bg-blue",
    fg: "text-cream",
    iconBg: "bg-cream/15",
  },
  {
    title: "Libre de TACC",
    text: "Segura, auténtica y sabrosa",
    icon: "M12 2v20 M8 5c0 2 2 2 2 4s-2 2-2 4 2 2 2 4 M16 5c0 2-2 2-2 4s2 2 2 4-2 2-2 4 M3 21l18-18",
    bg: "bg-tan",
    fg: "text-brown",
    iconBg: "bg-brown/10",
  },
  {
    title: "Cuidada",
    text: "Atención en cada detalle",
    icon: "M12 20s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 5c-2.5 4.65-9.5 9-9.5 9Z",
    bg: "bg-rose",
    fg: "text-brown",
    iconBg: "bg-brown/10",
  },
];
---

<section id="propuesta" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="section-title max-w-3xl text-4xl text-brown sm:text-5xl">
      ¿Cómo es la cocina en Nature?
    </h2>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        pilares.map((pilar) => (
          <article
            class:list={[
              "rounded-3xl p-8 transition-transform duration-300 hover:-translate-y-2",
              pilar.bg,
              pilar.fg,
            ]}
          >
            <span class:list={["flex h-16 w-16 items-center justify-center rounded-full", pilar.iconBg]}>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-8 w-8"
                aria-hidden="true"
              >
                <path d={pilar.icon} />
              </svg>
            </span>
            <h3 class:list={["mt-8 text-2xl font-semibold", pilar.fg]}>{pilar.title}</h3>
            <p class="mt-2 opacity-80">{pilar.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
