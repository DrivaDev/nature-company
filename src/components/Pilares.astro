---
const pilares = [
  { title: "Artesanal", text: "Hecha a mano, con tiempo", icon: "beans" },
  { title: "Sostenible", text: "Respeto por el origen", icon: "leaf" },
  { title: "Libre de TACC", text: "Segura, auténtica y sabrosa", icon: "gluten-free" },
  { title: "Cuidada", text: "Atención en cada detalle", icon: "seal" },
];
---

<section id="propuesta" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl">
      <p class="section-eyebrow">Nuestra propuesta</p>
      <h2 class="mt-3 font-display text-4xl text-brown sm:text-5xl">Cuatro ideas que guían cada plato</h2>
    </div>

    <div class="mt-14 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-4">
        {
          pilares.map((pilar) => (
            <div class="flex flex-col items-start gap-4">
              <span class="text-brown">
                <svg viewBox="0 0 48 48" fill="none" class="h-12 w-12" aria-hidden="true">
                  {pilar.icon === "beans" && (
                    <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <ellipse cx="19" cy="24" rx="8" ry="12" transform="rotate(-18 19 24)" />
                      <path d="M17 13c2 4 2 18 0 22" transform="rotate(-18 19 24)" />
                      <ellipse cx="31" cy="27" rx="8" ry="12" transform="rotate(-18 31 27)" />
                      <path d="M29 16c2 4 2 18 0 22" transform="rotate(-18 31 27)" />
                    </g>
                  )}
                  {pilar.icon === "leaf" && (
                    <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 36C10 20 24 8 38 10c2 14-10 28-26 26Z" />
                      <path d="M14 34C22 30 30 22 33 15" />
                    </g>
                  )}
                  {pilar.icon === "gluten-free" && (
                    <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="24" cy="24" r="15" />
                      <line x1="13.5" y1="13.5" x2="34.5" y2="34.5" />
                    </g>
                  )}
                  {pilar.icon === "seal" && (
                    <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M24 7l4 3.4 5.2-.7 2 4.9 4.9 2-.7 5.2L42 34l-3.4 4-5.2-.7-2 4.9L26 41l-4 0-4.9 1.2-2-4.9L9.9 38 6.5 34 7.7 28.8 3 26l1.2-5.2L3.9 14.6l2-4.9 5.2.7L16.3 7l4.9 1.2Z" />
                      <path d="M18 24l4.5 4.5L31 20" />
                    </g>
                  )}
                </svg>
              </span>
              <div>
                <h3 class="font-display text-2xl leading-none text-brown">{pilar.title}</h3>
                <p class="mt-2 text-ink-muted">{pilar.text}</p>
              </div>
            </div>
          ))
        }
    </div>
  </div>
</section>
