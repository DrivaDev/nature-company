---
const mapEmbedSrc = "https://www.google.com/maps?q=Dardo+Rocha+1394,+Mart%C3%ADnez,+Buenos+Aires&output=embed";
const mapHref = "https://maps.app.goo.gl/uYUQTZJ5sJiga9Wr7";
---

<section id="encontranos" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="section-title text-4xl text-brown sm:text-5xl">Encontrános</h2>

    <div class="mt-14 grid gap-10 lg:grid-cols-[1fr_1.3fr] lg:gap-16">
      <div>
        <p class="text-2xl font-semibold text-brown">Dardo Rocha 1394, Martinez</p>
        <a href={mapHref} target="_blank" rel="noopener noreferrer" class="btn btn-outline mt-8">
          Poner dirección en Google Maps
        </a>
      </div>

      <div class="overflow-hidden rounded-3xl border border-brown/10">
        <iframe
          src={mapEmbedSrc}
          width="100%"
          height="420"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Nature Company Resto en Dardo Rocha 1394, Martínez"
        ></iframe>
      </div>
    </div>
  </div>
</section>
