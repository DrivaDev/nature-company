---
const mapEmbedSrc = "https://www.google.com/maps?q=Dardo+Rocha+1394,+Mart%C3%ADnez,+Buenos+Aires&output=embed";
const mapHref = "https://maps.app.goo.gl/uYUQTZJ5sJiga9Wr7";
---

<section id="encontranos" class="bg-cream px-5 py-24 sm:px-8 sm:py-32">
  <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] border border-brown/15 bg-cream-soft">
    <div class="grid lg:grid-cols-[1fr_1.25fr]">
      <div class="flex flex-col justify-center px-8 py-12 sm:px-12">
        <h2 class="font-display text-4xl italic text-brown sm:text-5xl">Encontrános</h2>
        <p class="mt-6 text-xl font-bold tracking-wide text-ink">NATURE COMPANY RESTO</p>
        <address class="mt-5 space-y-1 not-italic text-lg text-ink-muted">
          <p>Dardo Rocha 1394, Martínez</p>
          <p><a href="tel:+5491171434499" class="hover:text-orange">+54 9 11 7143-4499</a></p>
          <p><a href="mailto:naturecompanyresto@gmail.com" class="hover:text-orange">naturecompanyresto@gmail.com</a></p>
        </address>
        <a href={mapHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary mt-9 self-start">
          Cómo llegar
        </a>
      </div>

      <div class="min-h-[340px] lg:min-h-[460px]">
        <iframe
          src={mapEmbedSrc}
          width="100%"
          height="100%"
          style="border:0"
          class="h-full min-h-[340px] w-full lg:min-h-[460px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Nature Company Resto en Dardo Rocha 1394, Martínez"
        ></iframe>
      </div>
    </div>
  </div>
</section>
